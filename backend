@app.route('/api/auth/signup', methods=['POST'])
def signup():
    data = request.get_json()
    name         = data.get('name')
    username     = data.get('username')
    password     = data.get('password')
    role         = data.get('role', 'public')
    station_code = data.get('stationCode')

    # Role-specific extra fields
    badge        = data.get('badge')
    rank         = data.get('rank')
    station_name = data.get('stationName')
    district     = data.get('district')
    state        = data.get('state')
    squad        = data.get('squad')
    official_id  = data.get('officialId')
    designation  = data.get('designation')
    department   = data.get('department')
    zone         = data.get('zone')

    if not name or not username or not password:
        return jsonify({'error': 'Missing required fields'}), 400

    # Role-specific validation
    if role == 'police' and (not badge or not rank or not station_code):
        return jsonify({'error': 'Badge number, rank, and station are required for Police Officers'}), 400
    if role == 'admin' and (not official_id or not designation or not department):
        return jsonify({'error': 'Official ID, designation, and department are required for Govt Officials'}), 400

    conn = get_db()
    existing = conn.execute('SELECT username FROM users WHERE username=?', (username,)).fetchone()
    if existing:
        conn.close()
        return jsonify({'error': 'Username already exists'}), 409

    conn.execute("""
        INSERT INTO users
        (username, password, role, display, station_code,
         badge, rank, station_name, district, state, squad,
         official_id, designation, department, zone)
        VALUES (?,?,?,?,?,?,?,?,?,?,?,?,?,?,?)
    """, (username, password, role, name, station_code,
           badge, rank, station_name, district, state, squad,
           official_id, designation, department, zone))
    conn.commit()
    conn.close()

    resp = {
        'username':    username,
        'role':        role,
        'display':     name,
        'stationCode': station_code,
        'token':       f"csn-{role}-{int(datetime.now().timestamp())}"
    }
    # Return all profile fields so frontend can use them immediately
    for key, val in [
        ('badge', badge), ('rank', rank), ('stationName', station_name),
        ('district', district), ('state', state), ('squad', squad),
        ('officialId', official_id), ('designation', designation),
        ('department', department), ('zone', zone)
    ]:
        if val:
            resp[key] = val
    return jsonify(resp), 201

