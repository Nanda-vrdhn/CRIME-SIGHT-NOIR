@app.route('/api/auth/login', methods=['POST'])
def login():
    data = request.get_json()
    username, password = data.get('username', ''), data.get('password', '')
    conn = get_db()
    u = conn.execute('SELECT * FROM users WHERE username=?', (username,)).fetchone()
    conn.close()
    if not u or u['password'] != password:
        return jsonify({'error': 'Invalid credentials'}), 401
    resp = {
        'username':    u['username'],
        'role':        u['role'],
        'display':     u['display'],
        'stationCode': u.get('station_code'),
        'token':       f"csn-{u['role']}-{int(datetime.now().timestamp())}"
    }
    # Include role-specific profile fields
    for f in ['badge','rank','station_name','district','state','squad',
               'official_id','designation','department','zone']:
        if u.get(f):
            resp[f] = u[f]
    return jsonify(resp)

