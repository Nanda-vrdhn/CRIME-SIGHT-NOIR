@app.route('/api/criminals/<criminal_id>', methods=['GET'])
def get_criminal(criminal_id):
    conn = get_db()
    criminal = conn.execute('SELECT * FROM criminals WHERE id=?', (criminal_id,)).fetchone()
    if not criminal:
        conn.close()
        return jsonify({'error': 'Criminal not found'}), 404
    cases = conn.execute("""
        SELECT c.fir_number, c.crime_type, c.severity, c.status,
               c.completion_pct, c.handling, c.investigation_type, c.arrest_date,
               ps.name AS station_name, ps.ps_code, ps.district, ps.state, ps.lat, ps.lng,
               o.name AS officer_name, o.rank AS officer_rank
        FROM cases c
        INNER JOIN police_stations ps ON ps.id = c.station_id
        LEFT  JOIN officers         o  ON o.id  = c.officer_id
        WHERE c.criminal_id = ?
        ORDER BY c.arrest_date DESC
    """, (criminal_id,)).fetchall()
    stations = conn.execute("""
        SELECT DISTINCT ps.*, COUNT(c.id) AS fir_count
        FROM cases c
        INNER JOIN police_stations ps ON ps.id = c.station_id
        WHERE c.criminal_id = ?
        GROUP BY ps.id
        ORDER BY fir_count DESC
    """, (criminal_id,)).fetchall()
    conn.close()
    return jsonify({'criminal': criminal, 'cases': cases, 'stations': stations})

