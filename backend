@app.route('/api/stations', methods=['GET'])
def get_stations():
    conn = get_db()
    rows = conn.execute("""
        SELECT ps.*,
               COUNT(c.id)                                               AS total_cases,
               SUM(CASE WHEN c.severity='Critical' THEN 1 ELSE 0 END)  AS critical_count,
               SUM(CASE WHEN c.status='Open'       THEN 1 ELSE 0 END)  AS open_count
        FROM police_stations ps
        LEFT JOIN cases c ON c.station_id = ps.id
        GROUP BY ps.id
        ORDER BY ps.state, ps.district
    """).fetchall()
    conn.close()
    return jsonify(rows)

